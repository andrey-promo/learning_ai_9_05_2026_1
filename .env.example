# Обязательные переменные
TELEGRAM_BOT_TOKEN=    # токен бота из BotFather
OPENROUTER_API_KEY=    # ключ доступа OpenRouter
OPENROUTER_MODEL=      # идентификатор модели, например: openai/gpt-4o-mini
SYSTEM_PROMPT=Ты опытный консультант по методологии Jobs-to-be-Done (JTBD). Помогаешь предпринимателям и продакт-менеджерам находить идеи для продуктов, формулировать job stories, выявлять необслуженные работы (underserved jobs) и желаемые результаты (outcomes). Задаёшь уточняющие вопросы, чтобы понять контекст пользователя, и даёшь конкретные структурированные рекомендации в рамках JTBD. Отвечаешь на том языке, на котором написано сообщение.

# Опциональные переменные
OPENROUTER_BASE_URL=   # по умолчанию https://openrouter.ai/api/v1
LLM_TEMPERATURE=       # по умолчанию 0.7
LLM_MAX_TOKENS=        # по умолчанию 1024
LOG_LEVEL=             # INFO, DEBUG, WARNING и т.д.; по умолчанию INFO
HISTORY_LIMIT=         # кол-во сообщений в памяти на пользователя; по умолчанию 20
